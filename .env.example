# Payload
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
PAYLOAD_SECRET=replace-me-with-a-32-byte-base64-secret
# Local: mongodb://localhost:27017/szz-flashcards
# Prod:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/szz-flashcards?retryWrites=true&w=majority
DATABASE_URI=mongodb://localhost:27017/szz-flashcards

# Auth.js (Google OAuth)
# Generate the same way as PAYLOAD_SECRET.
AUTH_SECRET=replace-me-with-a-32-byte-base64-secret
AUTH_TRUST_HOST=true

# Google OAuth (leave empty until the admin has seeded the Users allow-list)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public site URL (used as Payload serverURL, CORS/CSRF origin, and OAuth callback base)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
